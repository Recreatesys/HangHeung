<odoo>
    <record id="view_inventory_report_wizard" model="ir.ui.view">
        <field name="name">report.inventory.wizard.form</field>
        <field name="model">report.inventory.wizard</field>
        <field name="arch" type="xml">
            <form string="Pickup Slip Summary">
                <group>
                    <field name="start_date"/>
                    <field name="end_date"/>
                </group>
                <footer>
                    <button name="print_report"
                            type="object"
                            string="Print Report"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
