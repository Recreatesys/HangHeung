<odoo>
    <record id="view_move_form_inherit_cost_centre" model="ir.ui.view">
        <field name="name">account.move.form.inherit.cost.centre</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='line_ids']/list/field[@name='account_id']" position="after">
                <field name="cost_center_id" string="Cost Centre"/>
            </xpath>

        </field>
    </record>
</odoo>
