<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="custom_pos_receipt.ReceiptHeader" t-inherit="point_of_sale.ReceiptHeader" t-inherit-mode="extension">
        <!--<xpath expr="//div[@t-if='props.data.cashier']" position="after">
            <t t-if='props.data.partner'>
                <div>Client:
                    <t t-esc='props.data.partner.name' />
                </div>
            </t>
        </xpath>-->
        <xpath expr="//div[@class='pos-receipt-contact']/div[@t-if='props.data.company.name']" position="replace">
        </xpath>
        <t t-if="props.data.company.phone">
            <xpath expr="//div[@class='pos-receipt-contact']/div[@t-if='props.data.company.phone']" position="replace">
            </xpath>
        </t>
        <t t-if="props.data.company.vat">
            <xpath expr="//div[@class='pos-receipt-contact']/div[@t-if='props.data.company.vat']" position="replace">
            </xpath>
        </t>
        <xpath expr="//div[@class='pos-receipt-contact']/div[@t-if='props.data.company.email']" position="replace">
            <t t-if="props.data.company.email">
            </t>
        </xpath>
        <xpath expr="//div[@class='pos-receipt-contact']/div[@t-if='props.data.company.website']" position="replace">
             <t t-if="props.data.company.website">
             </t>
        </xpath>
        <xpath expr="//div[@t-if='props.data.cashier']" position="replace">
            <div t-if="props.data.cashier" class="cashier">
                <div t-esc="props.data.cashier" />
            </div>
        </xpath>
        <xpath expr="//div[@t-if='props.data.trackingNumber and !props.data.bigTrackingNumber']" position="replace">
            <span class="tracking-number fs-1" t-esc="props.data.orderRef" />
        </xpath>
    </t>
    <t t-name="custom_pos_receipt.remove_powered_by" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//div[@class='pos-receipt-order-data']/p[text()='Powered by Odoo']" position="replace">
        </xpath>
    </t>
</templates>