<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="custom_pos_receipt.ReceiptHeader" t-inherit="point_of_sale.ReceiptHeader" t-inherit-mode="extension">
        <!--<xpath expr="//div[@t-if='props.data.cashier']" position="after">
            <t t-if='props.data.partner'>
                <div>Client:
                    <t t-esc='props.data.partner.name' />
                </div>
            </t>
        </xpath>-->
        <xpath expr="//div[@class='pos-receipt-contact']/div[@t-if='props.data.company.name']" position="replace">
        </xpath>
        <t t-if="props.data.company.phone">
            <xpath expr="//div[@class='pos-receipt-contact']/div[@t-if='props.data.company.phone']" position="replace">
            </xpath>
        </t>
        <t t-if="props.data.company.vat">
            <xpath expr="//div[@class='pos-receipt-contact']/div[@t-if='props.data.company.vat']" position="replace">
            </xpath>
        </t>
        <xpath expr="//div[@class='pos-receipt-contact']/div[@t-if='props.data.company.email']" position="replace">
            <t t-if="props.data.company.email">
            </t>
        </xpath>
        <xpath expr="//div[@class='pos-receipt-contact']/div[@t-if='props.data.company.website']" position="replace">
             <t t-if="props.data.company.website">
             </t>
        </xpath>
        <xpath expr="//div[@t-if='props.data.header']" position="replace">
            <t t-if="props.data.header">
                <div style="white-space:pre-line; font-size: 12pt;">
                    <t t-esc="props.data.header"/>
                </div>
            </t>
        </xpath>
        <xpath expr="//div[@t-if='props.data.cashier']" position="replace">
            <div t-if="props.data.cashier" class="cashier">
            </div>
        </xpath>
        <xpath expr="//div[@t-if='props.data.trackingNumber and !props.data.bigTrackingNumber']" position="replace">
        </xpath>
        <xpath expr="//div[@t-if='props.data.cashier']" position="after">
            <div style="text-align: center; font-size: 18pt">
                發票（門市收據）
            </div>
        </xpath>
    </t>
    <t t-name="custom_pos_receipt.remove_powered_by" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//ReceiptHeader" position="after">
            <div style="text-align: left; font-size: 8pt; margin-top: 0px;">
                店铺：<t t-esc='props.data.headerData.storeName' /> <br/>
                收銀員：<t t-esc='props.data.cashier' /><br/>
                發票編碼：<t t-esc='props.data.name' /> <br/>
                會員號碼：<br/>
                <t t-if="props.data.recreate_pickup_date">
                    取貨日期：<t t-esc='props.data.recreate_pickup_date' /><br/>
                </t>
                <t t-if="props.data.recreate_pickup_address">
                    取貨地點：<t t-esc='props.data.recreate_pickup_address' /><br/>
                </t>
                日期:<t t-esc="props.data.date.split(' ')[0]" /> <span style="display:inline-block; width:10px;"></span>
                列印時間：<t t-esc="props.data.date.split(' ')[1]" />
            </div>
            <hr style="border: none; border-top: 1px solid #000000; margin: 2px 0;" />
            <div style="text-align: left; font-size: 10pt;">
                數量<span style="display:inline-block; width:10px;"></span>
                貨品名稱<span style="display:inline-block; width:10px;"></span>
                價格<span style="display:inline-block; width:10px;"></span>
            </div>
            <hr style="border: none; border-top: 1px solid #000000; margin: 2px 0;" />
        </xpath>
        <xpath expr="//div[@class='pos-receipt-taxes']/div[@class='text-center']" position="replace">
            <hr style="border: none; border-top: 1px solid #000000; margin: 2px 0;" />
        </xpath>
        <xpath expr="//div[@class='pos-receipt-amount receipt-total']/preceding-sibling::div[@class='text-center'][1]" position="replace">
            <hr style="border: none; border-top: 1px solid #000000; margin: 2px 0;" />
        </xpath>
        <xpath expr="//div[@class='pos-receipt-amount receipt-total']" position="before">
            <div class="pos-receipt-amount receipt-quantity">
                <span>總數量：</span>
                <span t-esc="props.data.headerData.totalQty" class="pos-receipt-right-align"/>
            </div>
        </xpath>
        <xpath expr="//div[@t-if='props.data.footer']" position="before">
            <t t-if="props.data.recreate_used_coupons and props.data.recreate_used_coupons.length">
                <hr style="border: none; border-top: 1px dashed #000000; margin: 4px 0;" />
                <div style="text-align: left; font-size: 9pt;">
                    <strong>已用優惠券 / Coupons Used:</strong>
                    <t t-foreach="props.data.recreate_used_coupons" t-as="c" t-key="c_index">
                        <div>- <t t-esc="c.code"/><t t-if="c.program"> (<t t-esc="c.program"/>)</t></div>
                    </t>
                </div>
            </t>
            <div style="text-align: center; font-size: 16pt;">
                多謝惠顧！
            </div>
        </xpath>
        <xpath expr="//div[@class='pos-receipt-order-data']/p[text()='Powered by Odoo']" position="replace">
        </xpath>
        <xpath expr="//div[@class='pos-receipt-order-data']/div[@t-esc='props.data.name']" position="replace">
        </xpath>
        <xpath expr="//div[@class='pos-receipt-order-data']/div[@id='order-date']" position="replace">
            <div style="font-size: 8pt; margin-top: -40px;">
                <hr style="border: none; border-top: 1px solid #000000; margin: 2px 0;" />
                Thank you and have a nice day!<br/>
                www.hangheung.com.hk<br/>
                E.&amp;O.E.
            </div>
        </xpath>
    </t>
</templates>