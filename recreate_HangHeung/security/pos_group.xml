<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        POS Group is the role group for "POS User" in the 6-role partner-access
        framework. The actual partner ir.rule lives in security/role_groups.xml
        (rule_partner_pos_user_role). The old global rule (id 331) is
        deactivated by the post-migrate script.
    -->

    <record id="group_pos_user" model="res.groups">
        <field name="name">POS Group</field>
        <field name="comment">POS User role: can see retail customers (no flags) and internal contacts. Hides vendors, B2B customers, and children of non-internal vendors / B2B customers.</field>
    </record>
</odoo>
