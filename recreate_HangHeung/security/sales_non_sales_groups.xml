<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sales group: hide vendors and children of vendors -->
    <record id="group_sales_user" model="res.groups">
        <field name="name">Sales</field>
        <field name="comment">Users in this group cannot see contacts marked as Vendor, nor contacts whose parent is a Vendor.</field>
    </record>

    <record id="rule_partner_sales_no_vendor" model="ir.rule">
        <field name="name">Sales: hide Vendor partners (and their children)</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="global" eval="True"/>
        <field name="active" eval="True"/>
        <field name="domain_force">['|', ('partner_share', '=', False), '&amp;', ('vendor', '=', False), '|', ('parent_id', '=', False), ('parent_id.vendor', '=', False)] if user.has_group('recreate_HangHeung.group_sales_user') else [(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Non-Sales group: only show vendors and children of vendors -->
    <record id="group_non_sales_user" model="res.groups">
        <field name="name">Non-Sales</field>
        <field name="comment">Users in this group can ONLY see contacts marked as Vendor (or contacts whose parent is a Vendor).</field>
    </record>

    <record id="rule_partner_non_sales_only_vendor" model="ir.rule">
        <field name="name">Non-Sales: only show Vendor partners (and their children)</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="global" eval="True"/>
        <field name="active" eval="True"/>
        <field name="domain_force">['|', ('partner_share', '=', False), '|', ('vendor', '=', True), ('parent_id.vendor', '=', True)] if user.has_group('recreate_HangHeung.group_non_sales_user') else [(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
