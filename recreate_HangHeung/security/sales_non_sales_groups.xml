<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        These two groups (Sales / Purchase) date from the original 4-id-whitelist
        access model. They are still used as the role groups for Sales User and
        Purchase User in the 6-role partner-access framework (see
        security/role_groups.xml). The old global ir.rules that they referenced
        (rules id 332 and 333) are deactivated by the post-migrate script and
        replaced by group-bound rules in role_groups.xml.

        The "Non-Sales" group is renamed to "Purchase" here; the XML id
        group_non_sales_user is kept so existing user memberships are preserved.
    -->

    <record id="group_sales_user" model="res.groups">
        <field name="name">Sales</field>
        <field name="comment">Sales User role: can see customers (including B2B) and internal contacts. Hides vendors and children of non-internal vendors.</field>
    </record>

    <record id="group_non_sales_user" model="res.groups">
        <field name="name">Purchase</field>
        <field name="comment">Purchase User role (was "Non-Sales"): can see all vendors and internal contacts. Hides B2B and retail customers.</field>
    </record>
</odoo>
