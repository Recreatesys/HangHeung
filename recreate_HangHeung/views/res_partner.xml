<odoo>
    <data>

        <!--
            Simplified partner form used by the Customer field's Create &amp; Edit popup
            on Sale Orders. Shows only name + phone + mobile + email + address.
            Referenced via context={'form_view_ref': 'recreate_HangHeung.view_partner_form_simplified'}
            on sale.order's partner_id field.
        -->
        <record id="view_partner_form_simplified" model="ir.ui.view">
            <field name="name">res.partner.form.simplified</field>
            <field name="model">res.partner</field>
            <field name="priority">99</field>
            <field name="arch" type="xml">
                <form string="New Customer">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" required="1"/>
                                <field name="phone"/>
                                <field name="mobile"/>
                                <field name="email"/>
                            </group>
                            <group string="Address">
                                <field name="street" placeholder="Street..."/>
                                <field name="street2" placeholder="Street 2..."/>
                                <field name="city" placeholder="City"/>
                                <field name="state_id" placeholder="State / Province" options="{'no_quick_create': True, 'no_create_edit': True}"/>
                                <field name="zip" placeholder="ZIP"/>
                                <field name="country_id" placeholder="Country" options="{'no_quick_create': True, 'no_create_edit': True}"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_contact_form_inherit" model="ir.ui.view">
            <field name="name">Contact Form Inherit</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">

                <xpath expr="//span[@class='o_form_label o_td_label o_address_type']" position="before">
                    <field name="contact_number"/>
                    <field name="alternative_contact_name"/>
                </xpath>

                <xpath expr="//field[@name='vat']" position="after">
                    <field name="customer_credit_limit"/>
                    <field name="crdr_due_days"/>
                    <field name="customer_category_id"/>
                    <field name="purchase_auto_confirm"/>
                </xpath>

                <xpath expr="//field[@name='vat']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <xpath expr="//field[@name='website']" position="before">
                    <field name="fax_number"/>
                </xpath>

                <xpath expr="//field[@name='category_id']" position="after">
                    <field name="terms"/>
                    <field name="customer"/>
                    <field name='vendor'/>
                    <field name="is_internal_contact" groups="base.group_system"/>
                </xpath>

            </field>
        </record>

    </data>
</odoo>