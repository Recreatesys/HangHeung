<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_stock_backorder_confirmation_custom_form" model="ir.ui.view">
            <field name="name">stock.backorder.confirmation.custom.form</field>
            <field name="model">stock.backorder.confirmation.custom</field>
            <field name="arch" type="xml">
                <form string="Reason for Partial Delivery">
                    <group>
                        <p class="o_label_info">
                            You have processed less products than the initial demand.
                            Please provide a reason code and choose how to proceed with the remaining quantity.
                        </p>
                        <field name="picking_id" invisible="1"/>
                        <!-- Changed to use the Many2one widget for 'reason_code' -->
                        <field name="reason_code"/>
                        <field name="backorder_option" widget="radio" options="{'horizontal': true}"/>
                    </group>
                    <footer>
                        <button name="action_confirm" type="object" string="Confirm" class="btn-primary"/>
                        <button name="action_discard" type="object" string="Discard" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>