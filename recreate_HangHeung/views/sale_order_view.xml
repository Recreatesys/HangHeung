<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_order_form_intercompany_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.intercompany.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='client_order_ref']" position="after">
                <field name="intercompany_source_po_name" readonly="1"
                       invisible="company_id != 2 or not intercompany_source_po_name"/>
            </xpath>
        </field>
    </record>
</odoo>
