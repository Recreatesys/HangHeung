<odoo>
    <data>

        <record id="view_purchase_order_form_inherit" model="ir.ui.view">
            <field name="name">Purchase Form Inherit</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='dest_address_id']" position="replace">
                    <field name="dest_address_id"
                           groups="stock.group_stock_multi_locations"
                           readonly="state in ['cancel', 'done', 'purchase']"
                           required="1"
                           domain="[('id', 'not in', [8885, 8886, 8887, 8888, 8889, 8890, 8891, 8892, 8893, 8896, 8897, 8898, 8899, 8901, 8904, 8905, 8919, 8940])]"/>
                </xpath>

            </field>
        </record>

    </data>
</odoo>