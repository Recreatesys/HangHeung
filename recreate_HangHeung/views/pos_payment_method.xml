<odoo>
    <data>
        <record id="view_pos_payment_method_form_inherit_refund" model="ir.ui.view">
            <field name="name">pos.payment.method.form.inherit.refund</field>
            <field name="model">pos.payment.method</field>
            <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='payment_method_type']" position="after">
                    <field name="refund_payment_method"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
  