<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_discount_config_list" model="ir.ui.view">
            <field name="name">discount.config.list</field>
            <field name="model">discount.config</field>
            <field name="arch" type="xml">
                <list default_order="id desc">
                    <field name="display_name"/>
                    <field name="discount_product"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                </list>
            </field>
        </record>

        <record id="view_discount_config_form" model="ir.ui.view">
            <field name="name">discount.config.form</field>
            <field name="model">discount.config</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="product_id"
                                   widget="many2many_tags"
                                   domain="[('available_in_pos', '=', True)]"
                                   options="{'no_create': True}" class="w-100"/>

                            <field name="discount_product"
                                   required="true"
                                   domain="[('available_in_pos', '=', True)]"
                                   options="{'no_create': True}" class="w-100"/>

                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="company_id"
                                   options="{'no_create': True, 'no_open': True}"
                                   groups="base.group_multi_company"/>
                            <field name="pos_config_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="is_bogo"/>
                        </group>

                        <notebook>
                            <page string="Discount Lines"  invisible="is_bogo">
                                <field name="discount_line_ids" invisible="is_bogo">
                                    <list editable="bottom">
                                        <field name="to_quantity" string="Quantity"/>
                                        <field name="discount_amount"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="discount_config_action" model="ir.actions.act_window">
            <field name="name">POS Discount</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">discount.config</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="discount_config_menu"
                  name="POS Discount"
                  action="discount_config_action"
                  parent="point_of_sale.menu_point_config_product"
                  sequence="2"/>
    </data>
</odoo>
