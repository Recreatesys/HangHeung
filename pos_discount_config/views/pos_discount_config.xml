<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_discount_config_list" model="ir.ui.view">
            <field name="name">discount.config.list</field>
            <field name="model">discount.config</field>
            <field name="arch" type="xml">
                <list default_order="id desc">
                    <field name="product_id"/>
                    <field name="discount_product"/>
                </list>
            </field>
        </record>

        <record id="view_discount_config_form" model="ir.ui.view">
            <field name="name">discount.config.form</field>
            <field name="model">discount.config</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <div class="row">
                                <div class="col-lg-6">
                                    <div>
                                        <label for="product_id"/>
                                        <field name="product_id" required="true" domain="[('available_in_pos', '=', True)]" options="{'no_create': True}" class="w-100"/>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div>
                                        <label for="discount_product"/>
                                        <field name="discount_product" required="true" domain="[('available_in_pos', '=', True)]" options="{'no_create': True}" class="w-100"/>
                                    </div>
                                </div>
                            </div>
                        </group>
                        <notebook>
                            <page string="Discount Lines">
                                <field name="discount_line_ids">
                                    <list editable="bottom">
                                        <field name="from_quantity"/>
                                        <field name="to_quantity"/>
                                        <field name="discount_amount"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="discount_config_action" model="ir.actions.act_window">
            <field name="name">POS Discount</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">discount.config</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="discount_config_menu"
                  name="POS Discount"
                  action="discount_config_action"
                  parent="point_of_sale.menu_point_config_product"
                  sequence="2"
                  />

    </data>
</odoo>