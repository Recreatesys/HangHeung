<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="sh_pos_theme_responsive.ProductScreen" t-inherit="point_of_sale.ProductScreen" t-inherit-mode="extension">
        <xpath expr="//div[@t-if='searchWord']" position="before">
            <t t-if="pos.models['sh.pos.theme.settings'] and pos.models['sh.pos.theme.settings'].getAll()[0] and pos.models['sh.pos.theme.settings'].getAll()[0].sh_pos_switch_view">
                <div class="sh_product_list_view">
                    <table class="table">
                        <thead>
                            <t t-if="pos.models['sh.pos.theme.settings'].getAll()[0].sh_display_product_image">
                                <th>Image</th>
                            </t>
                            <t t-if="pos.models['sh.pos.theme.settings'].getAll()[0].sh_display_product_name">
                                <th>Name</th>
                            </t>
                            <t t-if="pos.models['sh.pos.theme.settings'].getAll()[0].sh_display_product_code">
                                <th>Code</th>
                            </t>
                            <t t-if="pos.models['sh.pos.theme.settings'].getAll()[0].sh_display_product_type">
                                <th>Type</th>
                            </t>
                            <t t-if="pos.models['sh.pos.theme.settings'].getAll()[0].sh_display_product_onhand">
                                <th>On Hand</th>
                            </t>
                            <t t-if="pos.models['sh.pos.theme.settings'].getAll()[0].sh_display_product_uom">
                                <th>UOM</th>
                            </t>
                            <t t-if="pos.models['sh.pos.theme.settings'].getAll()[0].sh_display_product_price">
                                <th>Price</th>
                            </t>
                        </thead>
                        <tbody>
                            <t t-foreach="productsToDisplay" t-as="product" t-key="product.id">
                                <tr t-on-click="() => this.addProductToOrder(product)" t-att-data-product-id="props.productId" t-attf-aria-labelledby="article_product_{{props.productId}}" class="1563">
                                    <t t-if="pos.models['sh.pos.theme.settings'].getAll()[0].sh_display_product_image">
                                        <td>
                                            <t t-if="pos.models['sh.pos.theme.settings'].getAll()[0].sh_product_image_size == 'small_size'">
                                                <img t-att-src="this.getProductImage(product)" t-att-alt="props.name" class="small_size_image" />
                                            </t>
                                            <t t-if="pos.models['sh.pos.theme.settings'].getAll()[0].sh_product_image_size == 'medium_size'">
                                                <img t-att-src="this.getProductImage(product)" t-att-alt="props.name" class="medium_size_image" />
                                            </t>
                                            <t t-if="pos.models['sh.pos.theme.settings'].getAll()[0].sh_product_image_size == 'large_size'">
                                                <img t-att-src="this.getProductImage(product)" t-att-alt="props.name" class="large_size_image" />
                                            </t>
                                        </td>
                                    </t>
                                    <t t-if="pos.models['sh.pos.theme.settings'].getAll()[0].sh_display_product_name">
                                        <td>
                                            <t t-esc="getProductName(product)" />
                                        </td>
                                    </t>
                                    <t t-if="pos.models['sh.pos.theme.settings'].getAll()[0].sh_display_product_code">
                                        <td>
                                            <t t-if="product.default_code">
                                                <t t-esc="product.default_code" />
                                            </t>
                                            <t t-else="">
                                                -
                                            </t>
                                        </td>
                                    </t>
                                    <t t-if="pos.models['sh.pos.theme.settings'].getAll()[0].sh_display_product_type">
                                        <td>
                                            <t t-if="product.type == 'consu'">
                                                Goods
                                            </t>
                                            <t t-if="product.type == 'combo'">
                                                Combo
                                            </t>
                                            <t t-if="product.type == 'service'">
                                                Service
                                            </t>
                                        </td>
                                    </t>
                                    <t t-if="pos.models['sh.pos.theme.settings'].getAll()[0].sh_display_product_onhand">
                                        <td>
                                            <t t-if="product.qty_available > 0">
                                                <t t-esc="product.qty_available" />
                                            </t>
                                            <t t-else="">
                                                0
                                            </t>
                                        </td>
                                    </t>
                                    <t t-if="pos.models['sh.pos.theme.settings'].getAll()[0].sh_display_product_uom">
                                        <td>
                                            <t t-esc="product.uom_id.name" />
                                        </td>
                                    </t>
                                    <t t-if="pos.models['sh.pos.theme.settings'].getAll()[0].sh_display_product_price">
                                        <td>
                                            <t t-esc="this.getProductPrice(product)"/>
                                        </td>
                                    </t>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </xpath>

        <xpath expr="//div[hasclass('pads')]" position="attributes">
            <attribute name="class">pads sh_pads</attribute>
        </xpath>
        

        <xpath expr="//div[hasclass('product-screen')]" position="after">
            <t t-if="pos.models['sh.pos.theme.settings'] and pos.models['sh.pos.theme.settings'].getAll()[0] and pos.models['sh.pos.theme.settings'].getAll()[0].sh_action_button_position and pos.models['sh.pos.theme.settings'].getAll()[0].sh_action_button_position == 'bottom'">
                <div style="display:none">
                    <ControlButtons t-if="!ui.isSmall" onClickMore.bind="displayAllControlPopup" showRemainingButtons='true'/>
                </div>
                <div id="owl-demo" class="owl-carousel owl-theme sh_action_button">
                </div>
            </t>
        </xpath>

        <xpath expr="//div[hasclass('leftpane')]" position="before">
            <t t-if="pos.models['sh.pos.theme.settings'] and pos.models['sh.pos.theme.settings'].getAll()[0] and pos.models['sh.pos.theme.settings'].getAll()[0].sh_action_button_position and pos.models['sh.pos.theme.settings'].getAll()[0].sh_action_button_position == 'left_side'">
                <div t-attf-class="control-buttons d-flex justify-content-between gap-2 w-100 py-2">
                    <ControlButtons t-if="!ui.isSmall" onClickMore.bind="displayAllControlPopup" showRemainingButtons='true'/>
                </div>
            </t>
        </xpath>

        <xpath expr="//div[hasclass('rightpane')]" position="after">
            <t t-if="pos.models['sh.pos.theme.settings'] and pos.models['sh.pos.theme.settings'].getAll()[0] and pos.models['sh.pos.theme.settings'].getAll()[0].sh_action_button_position and pos.models['sh.pos.theme.settings'].getAll()[0].sh_action_button_position == 'right_side'">
                <div t-attf-class="control-buttons d-flex justify-content-between gap-2 w-100 py-2">
                    <ControlButtons t-if="!ui.isSmall" onClickMore.bind="displayAllControlPopup" showRemainingButtons='true'/>
                </div>
            </t>
        </xpath>

    </t>
</templates>
