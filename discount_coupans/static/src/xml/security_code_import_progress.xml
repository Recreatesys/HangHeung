<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="discount_coupans.SecurityCodeImportProgress">
        <div class="o_security_code_import_progress" style="margin-top: 8px;">
            <button type="button" class="btn btn-primary"
                    t-on-click="startImport"
                    t-att-disabled="state.running">
                <i class="fa fa-upload me-1"/>
                <t t-if="!state.running and !state.done">Start Import</t>
                <t t-elif="state.running">Importing...</t>
                <t t-else="">Re-run Import</t>
            </button>

            <div t-if="state.totalBatches > 0" class="mt-3">
                <div class="progress" style="height: 28px;">
                    <div class="progress-bar progress-bar-striped"
                         t-att-class="state.running ? 'progress-bar-animated bg-info' : 'bg-success'"
                         role="progressbar"
                         t-att-style="`width: ${percent}%;`"
                         t-att-aria-valuenow="percent"
                         aria-valuemin="0"
                         aria-valuemax="100">
                        <strong>
                            <t t-esc="state.currentBatch"/> / <t t-esc="state.totalBatches"/>
                            (<t t-esc="percent"/>%)
                        </strong>
                    </div>
                </div>
                <div class="d-flex justify-content-between mt-1" style="font-size: 12px; color: #555;">
                    <span>Total rows: <t t-esc="state.totalRows"/></span>
                    <span>Updated: <t t-esc="state.updated"/></span>
                    <span>No change: <t t-esc="state.noChange"/></span>
                    <span>Skipped: <t t-esc="state.skipped"/></span>
                </div>
            </div>

            <div t-if="state.message" class="mt-2" style="color: #555;">
                <t t-esc="state.message"/>
            </div>
            <div t-if="state.errorMessage" class="mt-2 alert alert-danger" role="alert">
                <t t-esc="state.errorMessage"/>
            </div>
        </div>
    </t>

</templates>
