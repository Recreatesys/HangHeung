<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="pos_editlistinput_inherit" t-inherit-mode="extension" t-inherit="point_of_sale.EditListInput">
        <xpath expr="//div[hasclass('input-group')]" position="after">
            <div class="input-group mb-3">
                <label class="form-label w-100 text-start mb-1">End Serial/Lot Number</label>
                <input
                        type="text"
                        placeholder="End Serial/Lot Number"
                        t-att-readOnly="!props.customInput"
                        t-att-value="state.secondInputValue"
                        class="popup-input list-line-input form-control form-control-lg w-75 mx-auto"
                        id="lot_id"
                        t-on-input="onSecondInput"
                        t-on-keyup="onSecondKeyup"
                        t-on-keydown="onSecondKeydown"
                        t-on-blur="onSecondBlur"
                        t-on-click="onSecondClick"/>

                <!-- Dropdown for second input -->
                <div class="options-dropdown" t-ref="options-dropdown-2"
                     t-if="!state.secondHideOptions">
                    <span t-if="secondDisplayedOptions.length === 0" class="no-match">No existing serial/lot number matching...</span>
                    <t t-foreach="secondDisplayedOptions" t-as="option" t-key="option">
                        <div class="option"
                             t-att-class="{'selected': option === state.secondSelectedOptionValue}"
                             t-on-click="() => this.onSecondSelectOption(option)">
                            <span t-esc="option" />
                        </div>
                    </t>
                </div>
            </div>
        </xpath>
    </t>
    <t t-name="pos_editlistpopup_inherit" t-inherit-mode="extension" t-inherit="point_of_sale.EditListPopup">
        <xpath expr="//button[hasclass('o-default-button')]" position="after">
            <button class="btn btn-secondary btn-lg lh-lg" t-on-click="props.close">Close</button>
        </xpath>
    </t>
</templates>
