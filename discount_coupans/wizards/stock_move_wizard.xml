<?xml version="1.0" encoding="UTF-8"?>
<odoo>
<record id="view_stock_move_add_wizard_form" model="ir.ui.view">
    <field name="name">stock.move.add.wizard.form</field>
    <field name="model">stock.move.add.wizard</field>
    <field name="arch" type="xml">
        <form string="Add Line Wizard">
            <group>
                <field name="location_id" invisible="1"/>
                <field name="product_id" invisible="1"/>
                <field name="quantity"/>
                <field name="lot_id" options="{'no_create': True}" domain='lot_id_domain'/>
            </group>
            <footer>
                <button string="Confirm" type="object" name="action_confirm" class="btn-primary"/>
                <button string="Cancel" class="btn-secondary" special="cancel"/>
            </footer>
        </form>
    </field>
</record>
</odoo>
