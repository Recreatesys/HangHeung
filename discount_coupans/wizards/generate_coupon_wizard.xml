<odoo>
    <record id="view_generate_coupon_wizard_form" model="ir.ui.view">
        <field name="name">generate.coupon.wizard.form</field>
        <field name="model">generate.coupon.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Coupons">

                <group>
                    <field name="order_id" readonly="1"/>
                    <field name="product_id"/>
                    <field name="prefix"/>
                </group>

                <group string="Coupon Range">
                    <field name="from_number" placeholder="e.g. 001200"/>
                    <field name="range_count" placeholder="e.g. 50"/>
                    <field name="to_number" readonly="1" force_save="1"/>
                </group>

                <group>
                    <field name="store_id"/>
                </group>

                <footer>
                    <button name="action_generate"
                            type="object"
                            string="Generate Coupons &amp; Confirm"
                            class="btn-primary"/>

                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>

            </form>
        </field>
    </record>
</odoo>
