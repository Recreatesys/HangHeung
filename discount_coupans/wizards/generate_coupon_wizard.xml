<odoo>
    <record id="view_generate_coupon_wizard_form" model="ir.ui.view">
        <field name="name">generate.coupon.wizard.form</field>
        <field name="model">generate.coupon.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate / Sell Coupons">

                <group>
                    <field name="order_id" readonly="1"/>
                    <field name="product_id" readonly="1"/>
                    <field name="coupon_action"/>
                </group>

                <!-- GENERATE MODE -->
                <group invisible="coupon_action == 'sell'">
                    <field name="prefix"/>
                    <field name="from_number"/>
                    <field name="range_count"/>
                    <field name="to_number" readonly="1"/>
                </group>

                <!-- SELL MODE -->
                <group invisible="coupon_action == 'generate'">
                    <field name="selected_coupon_ids"
                           widget="many2many_tags"
                           domain="[('id','in',available_coupon_ids)]"/>
                </group>

                <group>
                    <field name="store_id"/>
                </group>

                <footer>
                    <button name="action_generate"
                            type="object"
                            string="Process Coupons"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>

            </form>
        </field>
    </record>
</odoo>
