<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_security_code_import_wizard" model="ir.ui.view">
        <field name="name">loyalty.security.code.import.wizard.form</field>
        <field name="model">loyalty.security.code.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Coupon Security Codes">
                <sheet>
                    <group>
                        <field name="file_name"/>
                        <field name="file_data" filename="file_name"/>
                    </group>

                    <widget name="security_code_import_progress"/>

                    <group string="Result" invisible="not result_summary">
                        <field name="result_summary" nolabel="1" widget="text" readonly="1"/>
                    </group>

                    <p>
                        <strong>Excel format:</strong>
                        Column A = Coupon Code (e.g. HHC23000001),
                        Column B = Security Code (coupon code + 2 trailing digits, e.g. HHC2300000122).
                        Header row is auto-skipped. Allowed prefixes: HHC, BWC, CWC, EWC, DPC.
                    </p>
                    <p style="color: #666; font-size: 12px;">
                        Large files are imported in batches of 2,000 rows.
                        Each batch runs in its own transaction so the server stays responsive.
                    </p>
                </sheet>
                <footer>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_security_code_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Coupon Security Codes</field>
        <field name="res_model">loyalty.security.code.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_security_code_import_wizard"/>
        <field name="target">new</field>
    </record>

    <record id="server_action_security_code_import" model="ir.actions.server">
        <field name="name">Import Coupon Security Codes</field>
        <field name="model_id" ref="loyalty.model_loyalty_program"/>
        <field name="binding_model_id" ref="loyalty.model_loyalty_program"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">action = env['ir.actions.act_window']._for_xml_id('discount_coupans.action_security_code_import_wizard')</field>
    </record>
</odoo>
