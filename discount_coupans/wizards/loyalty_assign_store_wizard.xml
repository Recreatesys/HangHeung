<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_loyalty_assign_store_wizard_form" model="ir.ui.view">
        <field name="name">view.loyalty.assign.store.wizard.form</field>
        <field name="model">loyalty.assign.store.wizard</field>
        <field name="arch" type="xml">
            <form string="Assign Store">
                <group>
                    <field name="store_id" options="{'no_create': True, 'no_create_edit': True}" required="True"/>
                </group>
                <footer>
                    <button name="action_assign_store" type="object" string="Assign Store" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_loyalty_assign_store_wizard" model="ir.actions.act_window">
        <field name="name">Assign Store</field>
        <field name="res_model">loyalty.assign.store.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>