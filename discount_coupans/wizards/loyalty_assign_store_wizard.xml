<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_loyalty_assign_store_wizard_form" model="ir.ui.view">
        <field name="name">view.loyalty.assign.store.wizard.form</field>
        <field name="model">loyalty.assign.store.wizard</field>
        <field name="arch" type="xml">
            <form string="Assign Stores">
                <sheet>
                    <group>
                        <field name="common_store_id"/>
                        <field name="line_ids" nolabel="1" options="{'no_create': True}">
                            <list editable="bottom">
                                <field name="card_id" readonly="1" force_save="1"/>
                                <field name="store_id" options="{'no_create': True, 'no_create_edit': True}" required="True"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <footer>
                    <button name="action_assign_store" type="object" string="Assign Stores" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_loyalty_assign_store_wizard" model="ir.actions.act_window">
        <field name="name">Assign Store</field>
        <field name="res_model">loyalty.assign.store.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>