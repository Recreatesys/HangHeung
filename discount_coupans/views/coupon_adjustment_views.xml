<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_pos_session_form_inherit_coupon_adjustment" model="ir.ui.view">
        <field name="name">pos.session.form.inherit.coupon.adjustment</field>
        <field name="model">pos.session</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_session_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='move_id']" position="after">
                <field name="coupon_adjustment_move_id" readonly="1"
                       invisible="not coupon_adjustment_move_id"/>
                <field name="payment_reconciliation_move_id" readonly="1"
                       invisible="not payment_reconciliation_move_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_account_move_form_inherit_coupon_adjustment" model="ir.ui.view">
        <field name="name">account.move.form.inherit.coupon.adjustment</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Coupon Adjustment"
                       invisible="not coupon_adjustment_move_id and not coupon_adjustment_source_move_id">
                    <field name="coupon_adjustment_move_id" readonly="1"
                           invisible="not coupon_adjustment_move_id"/>
                    <field name="coupon_adjustment_source_move_id" readonly="1"
                           invisible="not coupon_adjustment_source_move_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
