<odoo>
    <record id="view_order_line_tree_inherit" model="ir.ui.view">
        <field name="name">sale.order.line.tree.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='order_line']/list/field[@name='price_subtotal']" position="after">
                <button name="generate_coupon_button"
                        type="object"
                        invisible="parent.state == 'sale'"
                        class="btn-secondary"
                        string="Generate/Sell Coupons"/>
            </xpath>

        </field>
    </record>
</odoo>
