<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="eg_pos_restrict_stock.Popup">
            <Dialog size="'md'" title="props.title" modalRef="modalRef">
            <main class="body">
                <div class='div-container'>
                        <div class='product-list'>
                            <t t-if="props.product_name">
                                <div class="product-name text-center">
                                    <span t-esc="props.product_name"/> Is Out of Stock.If you want to Still order Than Click on order.
                                </div>
                            </t>
                        </div>
                    </div>
            </main>
                <t t-set-slot="footer">
                 <button class="button conform btn btn-lg btn-primary" t-on-click="() => this.add_restrict_product()">
                    <t t-esc="props.confirmText"/>
               </button>
                    <button class="button cancel btn btn-lg btn-danger" t-on-click="() => this.cancel()">
                    <t t-esc="props.cancelText"/>
               </button>
            </t>
        </Dialog>
        </t>
</templates>
