<odoo>
    <template id="report_purchaseorder_document_inherit_hide_cost" inherit_id="purchase.report_purchaseorder_document">
        <xpath expr="//th[@name='th_price_unit']" position="attributes">
            <attribute name="groups">hide_cost_price.groups_view_cost_price</attribute>
        </xpath>
        <xpath expr="//th[@name='th_discount']" position="attributes">
            <attribute name="groups">hide_cost_price.groups_view_cost_price</attribute>
        </xpath>
        <xpath expr="//th[@name='th_taxes']" position="attributes">
            <attribute name="groups">hide_cost_price.groups_view_cost_price</attribute>
        </xpath>
        <xpath expr="//th[@name='th_subtotal']" position="attributes">
            <attribute name="groups">hide_cost_price.groups_view_cost_price</attribute>
        </xpath>

        <xpath expr="//span[@t-field='line.price_unit']" position="attributes">
            <attribute name="groups">hide_cost_price.groups_view_cost_price</attribute>
        </xpath>
        <xpath expr="//td[span[@class='text-align-bottom']/span[@t-field='line.discount']]" position="attributes">
            <attribute name="groups">hide_cost_price.groups_view_cost_price</attribute>
        </xpath>
        <xpath expr="//span[@t-field='line.price_subtotal']" position="attributes">
            <attribute name="groups">hide_cost_price.groups_view_cost_price</attribute>
        </xpath>

        <xpath expr="//div[@id='total']" position="attributes">
            <attribute name="groups">hide_cost_price.groups_view_cost_price</attribute>
        </xpath>
    </template>
</odoo>
