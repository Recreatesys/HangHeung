<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="mrp_consumption_variance_tree_view" model="ir.ui.view">
        <field name="name">mrp.consumption.variance.tree.view</field>
        <field name="model">mrp.consumption.variance</field>
        <field name="arch" type="xml">
            <list string="Mrp Consumption Variance" create="0">
                <field name="mo_id"/>
                <field name="product_id"/>
                <field name="bom_qty"/>
                <field name="consumed_qty"/>
                <field name="excess_qty"/>
            </list>
        </field>
    </record>

    <record id="action_mrp_consumption_variance" model="ir.actions.act_window">
        <field name="name">Mrp Consumption Variance</field>
        <field name="res_model">mrp.consumption.variance</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            No Mrp Consumption Variance Found
          </p>
        </field>
    </record>

   <menuitem id="menu_mrp_consumption_variance"
             name="Mrp Consumption Variance"
             parent="mrp.menu_mrp_manufacturing"
             action="action_mrp_consumption_variance"
             sequence="50"/>
</odoo>